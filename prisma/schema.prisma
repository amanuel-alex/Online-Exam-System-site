generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ------------------------------------------------------
// Enums
// ------------------------------------------------------

enum Role {
  SYSTEM_ADMIN
  ORG_ADMIN
  TEACHER
  EXAMINER
  STUDENT
}

enum OrgType {
  SCHOOL
  UNIVERSITY
  TVET
  COC
  NATIONAL
  OTHER
}

enum QuestionType {
  MCQ
  TRUE_FALSE
  ESSAY
  FILE_UPLOAD
}

enum AttemptStatus {
  IN_PROGRESS
  SUBMITTED
  GRADED
}

// ------------------------------------------------------
// Models
// ------------------------------------------------------

model Organization {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  type      OrgType  @default(OTHER)
  isActive  Boolean  @default(true)
  settings  Json?    // Structured: grading system, pass score, proctoring, exam types
  metadata  Json?    // Arbitrary extra data
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users     User[]
  exams     Exam[]
  questions Question[] // Link questions to the organization (question bank)

  @@index([slug])
  @@index([isActive])
}

model User {
  id             String        @id @default(uuid())
  email          String        @unique
  passwordHash   String
  firstName      String
  lastName       String
  role           Role          @default(STUDENT)
  organizationId String?       // Nullable because System Admins don't belong to one org
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  isActive       Boolean       @default(true)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  createdExams     Exam[]        @relation("ExamCreator")
  createdQuestions Question[]    @relation("QuestionCreator")
  attempts         Attempt[]     @relation("StudentAttempts")
  gradedAnswers    Answer[]      @relation("AnswerGrader")
  results          Result[]

  @@index([email])
  @@index([organizationId])
  @@index([role])
}

model Question {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdById    String
  createdBy      User         @relation("QuestionCreator", fields: [createdById], references: [id])
  type           QuestionType
  text           String       @db.Text
  points         Float        @default(1.0)
  difficulty     Int          @default(1)
  isArchived     Boolean      @default(false)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  options       Option[]
  examQuestions ExamQuestion[]
  answers       Answer[]

  @@index([organizationId])
  @@index([type])
}

model Option {
  id         String   @id @default(uuid())
  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  text       String
  isCorrect  Boolean  @default(false)
  orderIndex Int      @default(0) // Control display order

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  answers Answer[] // To track if a student selected this option

  @@index([questionId])
}

model Exam {
  id                 String       @id @default(uuid())
  title              String
  description        String?      @db.Text
  organizationId     String
  organization       Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdById        String
  createdBy          User         @relation("ExamCreator", fields: [createdById], references: [id])
  
  // Settings
  startTime          DateTime?
  endTime            DateTime?
  durationMinutes    Int?         // Overall exam timer limit
  maxAttempts        Int          @default(1)
  randomizeQuestions Boolean      @default(false)
  isPublished        Boolean      @default(false)
  passPercentage     Float        @default(50.0)
  
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  examQuestions ExamQuestion[]
  attempts      Attempt[]

  @@index([organizationId])
  @@index([isPublished])
}

model ExamQuestion {
  id             String   @id @default(uuid())
  examId         String
  exam           Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  questionId     String
  question       Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  orderIndex     Int      // Serves as ordering if randomizeQuestions is false
  pointsOverride Float?   // Optional override for points on this specific exam

  @@unique([examId, questionId])
  @@index([examId])
}

model Attempt {
  id            String        @id @default(uuid())
  examId        String
  exam          Exam          @relation(fields: [examId], references: [id], onDelete: Cascade)
  studentId     String
  student       User          @relation("StudentAttempts", fields: [studentId], references: [id], onDelete: Cascade)
  
  attemptNumber Int           @default(1)
  startTime     DateTime      @default(now())
  endTime       DateTime?
  status        AttemptStatus @default(IN_PROGRESS)
  
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  answers Answer[]
  result  Result?

  @@unique([examId, studentId, attemptNumber]) // Prevent duplicate attempt numbers
  @@index([examId])
  @@index([studentId])
  @@index([status])
}

model Answer {
  id         String   @id @default(uuid())
  attemptId  String
  attempt    Attempt  @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  
  // Polymorphic-like storage based on question type
  textAnswer String?  @db.Text // Used for ESSAY
  optionId   String?           // Used for MCQ / TRUE_FALSE
  option     Option?  @relation(fields: [optionId], references: [id])
  fileUrl    String?           // Used for FILE_UPLOAD
  
  // Grading & Evaluation
  isAutoGraded Boolean  @default(false)
  score        Float?   
  evalComment  String?  @db.Text
  gradedById   String?
  gradedBy     User?    @relation("AnswerGrader", fields: [gradedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([attemptId, questionId]) // A student has one definitive answer per question per attempt
  @@index([attemptId])
  @@index([questionId])
}

model Result {
  id         String   @id @default(uuid())
  attemptId  String   @unique
  attempt    Attempt  @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  studentId  String
  student    User     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  
  totalScore Float
  maxScore   Float
  percentage Float    // Stored physically for ultra-fast dashboard queries
  isPassed   Boolean
  
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([studentId])
  @@index([attemptId])
  @@index([isPassed])
}
