generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ------------------------------------------------------
// Enums
// ------------------------------------------------------

enum Role {
  SYSTEM_ADMIN
  ORG_ADMIN
  TEACHER
  EXAMINER
  STUDENT
}

enum OrgType {
  SCHOOL
  UNIVERSITY
  TVET
  COC
  NATIONAL
  OTHER
}

enum QuestionType {
  MCQ
  TRUE_FALSE
  ESSAY
  FILE_UPLOAD
}

enum AttemptStatus {
  IN_PROGRESS
  SUBMITTED
  GRADED
}

enum QuestionDifficulty {
  EASY
  MEDIUM
  HARD
  EXPERT
}

enum SessionStatus {
  SCHEDULED
  ACTIVE
  COMPLETED
  CANCELLED
}

// ------------------------------------------------------
// Models
// ------------------------------------------------------

model Organization {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  type      OrgType  @default(OTHER)
  isActive  Boolean  @default(true)
  settings  Json?    // Structured: grading system, pass score, proctoring, exam types
  metadata  Json?    // Arbitrary extra data
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users     User[]
  exams     Exam[]
  sessions  ExamSession[]
  questions Question[] // Link questions to the organization (question bank)

  @@index([slug])
  @@index([isActive])
}

model User {
  id             String        @id @default(uuid())
  email          String        @unique
  passwordHash   String
  firstName      String
  lastName       String
  role           Role          @default(STUDENT)
  organizationId String?       // Nullable because System Admins don't belong to one org
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  isActive       Boolean       @default(true)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  createdExams     Exam[]        @relation("ExamCreator")
  createdQuestions Question[]    @relation("QuestionCreator")
  attempts         ExamAttempt[] @relation("StudentAttempts")
  gradedAnswers    AttemptAnswer[] @relation("AnswerGrader")
  results          Result[]
  sessionsCreated  ExamSession[]
  sessionEnrols    ExamSessionUser[]

  @@index([email])
  @@index([organizationId])
  @@index([role])
}

model Question {
  id             String             @id @default(uuid())
  organizationId String
  organization   Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdById    String
  explanation    String?            @db.Text
  isArchived     Boolean            @default(false)
  
  difficulty     QuestionDifficulty @default(MEDIUM)
  subject        String?            // e.g. "Mathematics", "History"
  topic          String?            // e.g. "Algebra", "World War II"
  tags           String[]           // Free-form tags for flexible filtering
  
  currentVersionId String?          @unique
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  versions      QuestionVersion[]
  examQuestions ExamQuestion[]
  answers       AttemptAnswer[]

  @@index([organizationId])
  @@index([subject])
  @@index([isArchived])
}

model QuestionVersion {
  id             String             @id @default(uuid())
  questionId     String
  question       Question           @relation(fields: [questionId], references: [id], onDelete: Cascade)
  versionNumber  Int                @default(1)
  
  type           QuestionType
  text           String             @db.Text
  points         Float              @default(1.0)
  explanation    String?            @db.Text
  
  createdById    String
  createdBy      User               @relation(fields: [createdById], references: [id])
  createdAt      DateTime           @default(now())

  attachments    String[]           // List of URLs to media/PDFs
  options        Option[]
  examQuestions  ExamQuestion[]
  answers        AttemptAnswer[]

  @@unique([questionId, versionNumber])
  @@index([questionId])
}

  @@index([organizationId])
  @@index([type])
  @@index([difficulty])
  @@index([subject])
  @@index([isArchived])
}

model Option {
  id                String          @id @default(uuid())
  questionId        String?         // Legacy
  questionVersionId String
  questionVersion   QuestionVersion @relation(fields: [questionVersionId], references: [id], onDelete: Cascade)
  text              String
  isCorrect  Boolean  @default(false)
  orderIndex Int      @default(0) // Control display order

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  answers AttemptAnswer[] // To track if a student selected this option

  @@index([questionId])
}

model Exam {
  id                 String       @id @default(uuid())
  title              String
  description        String?      @db.Text
  organizationId     String
  organization       Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdById        String
  createdBy          User         @relation("ExamCreator", fields: [createdById], references: [id])
  
  // Settings
  startTime          DateTime?
  endTime            DateTime?
  durationMinutes    Int?         // Overall exam timer limit
  maxAttempts        Int          @default(1)
  randomizeQuestions Boolean      @default(false)
  isPublished        Boolean      @default(false)
  passPercentage     Float        @default(50.0)
  
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  examQuestions ExamQuestion[]
  sessions      ExamSession[]
  attempts      ExamAttempt[]

  @@index([organizationId])
  @@index([isPublished])
}

model ExamQuestion {
  id             String   @id @default(uuid())
  examId         String
  exam           Exam            @relation(fields: [examId], references: [id], onDelete: Cascade)
  questionId     String
  question       Question        @relation(fields: [questionId], references: [id], onDelete: Cascade)
  versionId      String?
  version        QuestionVersion? @relation(fields: [versionId], references: [id])
  orderIndex     Int      // Serves as ordering if randomizeQuestions is false
  pointsOverride Float?   // Optional override for points on this specific exam

  @@unique([examId, questionId])
  @@index([examId])
}

model ExamAttempt {
  id            String        @id @default(uuid())
  examId        String
  exam          Exam          @relation(fields: [examId], references: [id], onDelete: Cascade)
  studentId     String
  student       User          @relation("StudentAttempts", fields: [studentId], references: [id], onDelete: Cascade)
  
  sessionId     String?
  session       ExamSession?  @relation(fields: [sessionId], references: [id])
  
  attemptNumber Int           @default(1)
  startTime     DateTime      @default(now())
  endTime       DateTime?
  status        AttemptStatus @default(IN_PROGRESS)
  
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  answers AttemptAnswer[]
  result  Result?

  @@unique([examId, studentId, attemptNumber]) // Prevent duplicate attempt numbers
  @@index([examId])
  @@index([studentId])
  @@index([status])
}

model AttemptAnswer {
  id         String   @id @default(uuid())
  attemptId  String
  attempt    ExamAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  versionId  String?
  version    QuestionVersion? @relation(fields: [versionId], references: [id])
  
  // Polymorphic-like storage based on question type
  textAnswer      String?  @db.Text // Used for ESSAY
  selectedOptions String[]           // Used for MCQ (support multiple selection)
  optionId        String?           // Deprecated legacy field (keeping for compatibility)
  option          Option?  @relation(fields: [optionId], references: [id])
  fileUrl         String?           // Used for FILE_UPLOAD
  
  // Grading & Evaluation
  isAutoGraded Boolean  @default(false)
  score        Float?   
  evalComment  String?  @db.Text
  gradedById   String?
  gradedBy     User?    @relation("AnswerGrader", fields: [gradedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([attemptId, questionId]) // A student has one definitive answer per question per attempt
  @@index([attemptId])
  @@index([questionId])
}

model Result {
  id         String      @id @default(uuid())
  attemptId  String      @unique
  attempt    ExamAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  studentId  String
  student    User     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  
  totalScore Float
  maxScore   Float
  percentage Float    // Stored physically for ultra-fast dashboard queries
  isPassed   Boolean
  isReleased Boolean  @default(false)
  releasedAt DateTime?
  
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([studentId])
  @@index([attemptId])
  @@index([isPassed])
}

model ExamSession {
  id             String       @id @default(uuid())
  title          String
  examId         String
  exam           Exam         @relation(fields: [examId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdById    String
  createdBy      User         @relation(fields: [createdById], references: [id])
  
  startTime      DateTime
  endTime        DateTime
  
  status         SessionStatus @default(SCHEDULED)
  isPublic       Boolean       @default(false) // If true, anyone in the org can join. If false, only mapped users.

  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  sessionUsers   ExamSessionUser[]
  attempts       ExamAttempt[]

  @@index([examId])
  @@index([organizationId])
  @@index([status])
}

model ExamSessionUser {
  id        String      @id @default(uuid())
  sessionId String
  session   ExamSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([sessionId, userId])
}

model AuditLog {
  id             String   @id @default(uuid())
  userId         String?
  user           User?    @relation(fields: [userId], references: [id])
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  
  action         String   // e.g. "USER_LOGIN", "EXAM_START", "QUESTION_EDIT", "SUSPICIOUS_ACTIVITY"
  metadata       Json?    // e.g. { ip: "...", browser: "...", oldVersion: "..." }
  
  timestamp      DateTime @default(now())

  @@index([userId])
  @@index([organizationId])
  @@index([action])
  @@index([timestamp])
}
